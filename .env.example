# Anthropic API Key — KEEP SECRET, never commit .env to git
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Moodle OAuth 2 settings (configure in Moodle Admin > Server > OAuth 2 services)
MOODLE_BASE_URL=https://moodle.braou.ac.in
MOODLE_CLIENT_ID=bodhiplanner
MOODLE_CLIENT_SECRET=your-client-secret-here

# Session secret (random string, generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-char-string

# App settings
NODE_ENV=production
PORT=3001
BASE_PATH=/bodhiplanner
